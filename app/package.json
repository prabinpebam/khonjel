{
  "name": "khonjel-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Khonjel",
  "description": "Khonjel — local-first voice productivity app (mock-data frontend, no backend).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint .",
    "lint:ds": "node scripts/ds-lint.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:quick": "npm run typecheck && npm run lint && npm run lint:ds && npm run test",
    "verify": "npm run verify:quick && npm run build",
    "eval": "playwright test --config=playwright.config.mjs",
    "eval:headed": "playwright test --config=playwright.config.mjs --headed",
    "eval:electron": "npm run build && npm run build:electron && playwright test --config=playwright.electron.config.mjs",
    "eval:shots": "node scripts/eval-shots.mjs",
    "gen:icon": "node scripts/gen-icon.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "fetch:llama": "node scripts/fetch-llama.mjs",
    "electron": "npm run build:electron && electron .",
    "package": "npm run gen:icon && npm run build && npm run build:electron && electron-builder --win portable",
    "package:dir": "npm run gen:icon && npm run build && npm run build:electron && electron-builder --dir"
  },
  "dependencies": {
    "@lobehub/icons-static-svg": "^1.91.0",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.24.2",
    "eslint": "^10.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.khonjel.app",
    "productName": "Khonjel",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.png"
    },
    "portable": {
      "artifactName": "Khonjel-${version}-portable.exe"
    }
  }
}
